# Copy this file to .env and fill in real values before running `docker compose up`.
# All variables are optional - sensible defaults are used if not set
# (the app will run, but AI feedback / code execution features will be disabled
# until valid Groq / JDoodle credentials are provided).

JWT_SECRET=CHANGE_ME_SUPER_SECRET_64_CHARS_MINIMUM____________________

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1200

JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=
